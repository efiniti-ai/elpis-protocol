# Local-only working materials (NEVER commit, NEVER push)
# These directories and patterns hold pitch decks, internal product details
# and confidential funding/customer materials that must not leak into the
# public Open-Source repository. Re-entry from any internal mirror, branch
# checkout or backup restore is blocked here.
working-files/
presentation/
pitch/
pitches/
internal/
private/
confidential/
**/working-files/
**/presentation/

